{
  "name": "braid",
  "version": "26.1.6",
  "description": "Git worktree & Claude Code session manager",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/gedeagas/braid.git"
  },
  "homepage": "https://getbraid.dev",
  "bugs": {
    "url": "https://github.com/gedeagas/braid/issues"
  },
  "main": "./out/main/index.js",
  "scripts": {
    "dev": "electron-vite dev",
    "prebuild": "vitest run",
    "build": "electron-vite build",
    "preview": "electron-vite preview",
    "rebuild": "rm -rf out && electron-vite build && electron-vite preview",
    "package": "yarn build && node scripts/package.js",
    "package:arm64": "yarn build && node scripts/package.js --arch arm64",
    "package:x64": "yarn build && node scripts/package.js --arch x64",
    "package:unsigned": "yarn build && node scripts/package.js --unsigned",
    "postinstall": "npx @electron/rebuild && node scripts/patch-sdk.js && node scripts/patch-electron.js && node scripts/vmp-sign-dev.js",
    "typecheck:node": "tsc --noEmit -p tsconfig.node.json",
    "typecheck:web": "tsc --noEmit -p tsconfig.web.json",
    "typecheck": "npm run typecheck:node && npm run typecheck:web",
    "test": "vitest run",
    "test:watch": "vitest",
    "release": "node scripts/release.js",
    "changelog": "node scripts/changelog.js",
    "generate-icon": "node scripts/generate-icon.js"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "0.2.112",
    "@floating-ui/react": "^0.27.19",
    "@mobilenext/mobilecli": "^0.1.62",
    "@modelcontextprotocol/sdk": "^1.28.0",
    "@monaco-editor/react": "^4.7.0",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-popover": "^1.1.15",
    "@react-symbols/icons": "^1.3.1",
    "@tiptap/core": "^3.22.0",
    "@tiptap/extension-image": "^3.22.0",
    "@tiptap/extension-placeholder": "^3.22.0",
    "@tiptap/extension-task-item": "^3.22.0",
    "@tiptap/extension-task-list": "^3.22.0",
    "@tiptap/extension-typography": "^3.22.0",
    "@tiptap/pm": "^3.22.0",
    "@tiptap/react": "^3.22.0",
    "@tiptap/starter-kit": "^3.22.0",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/xterm": "^6.0.0",
    "ansi-to-html": "^0.7.2",
    "electron-log": "^5.4.3",
    "electron-updater": "6.8.3",
    "i18next": "^25.10.10",
    "i18next-browser-languagedetector": "^8.2.1",
    "lodash.throttle": "^4.1.1",
    "marked": "^18.0.0",
    "monaco-editor": "^0.52.0",
    "node-pty": "^1.1.0",
    "react": "^19.0.0",
    "react-device-mockup": "^1.0.0",
    "react-dom": "^19.0.0",
    "react-hotkeys-hook": "^5.2.4",
    "react-i18next": "^16.6.6",
    "react-markdown": "^10.1.0",
    "react-virtuoso": "^4.18.3",
    "rehype-highlight": "^7.0.2",
    "remark-gfm": "^4.0.1",
    "shiki": "^4.0.2",
    "simple-git": "^3.27.0",
    "tiptap-markdown": "^0.9.0",
    "tslib": "^2.8.1",
    "zod": "^4.3.6",
    "zustand": "^5.0.3"
  },
  "devDependencies": {
    "@electron/notarize": "^2.3.0",
    "@electron/osx-sign": "^1.3.1",
    "@electron/packager": "^18.3.5",
    "@electron/rebuild": "^3.7.0",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/react": "^16.3.2",
    "@types/lodash.throttle": "^4.1.9",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.4.0",
    "electron": "https://github.com/castlabs/electron-releases#v39.8.0+wvcus",
    "electron-installer-dmg": "^5.0.1",
    "electron-vite": "^3.0.0",
    "jsdom": "^29.0.1",
    "typescript": "^5.7.0",
    "vite": "^6.2.0",
    "vitest": "^4.1.2"
  },
  "packageManager": "yarn@4.13.0+sha512.5c20ba010c99815433e5c8453112165e673f1c7948d8d2b267f4b5e52097538658388ebc9f9580656d9b75c5cc996f990f611f99304a2197d4c56d21eea370e7"
}
